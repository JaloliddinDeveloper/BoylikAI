# ──────────────────────────────────────────────────────────────────────────────
# BoylikAI — Production Environment Variables
# Copy to .env on your DigitalOcean server. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
DOMAIN=api.yourdomain.com
GITHUB_REPO=your-github-username
IMAGE_TAG=latest

# ── SSL ────────────────────────────────────────────────────────────────────────
LETSENCRYPT_EMAIL=admin@yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# Use a strong random password: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_32_CHARS

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_RANDOM_32_CHARS

# ── AI ─────────────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Telegram ───────────────────────────────────────────────────────────────────
# BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret-minimum-32-characters
TELEGRAM_WEBHOOK_URL=https://api.yourdomain.com/api/webhook/telegram

# ── Monitoring ─────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Generate Seq password hash:
#   docker run --rm datalust/seq config hash --plaintext your-password
SEQ_ADMIN_PASSWORD_HASH=CHANGE_ME_SEQ_HASH

# ── Whisper (lokal ovoz transkriptsiyasi) ──────────────────────────────────────
# API key shart emas — model serverda lokal ishlaydi.
# Birinchi ishga tushganda model avtomatik yuklanadi (~142 MB).
# ModelType: Tiny(75MB/tez) | Base(142MB/tavsiya) | Small(466MB/sifatli)
WHISPER_MODEL_TYPE=Base
WHISPER_LANGUAGE=uz

# ── GitHub Secrets Setup ──────────────────────────────────────────────────────
# GitHub → Settings → Secrets → Actions da quyidagilarni qo'shing:
#
#   DO_HOST                   = server IP manzili
#   DO_USER                   = boylikaI  (yoki root birinchi sozlashda)
#   DO_SSH_KEY                = ~/.ssh/id_ed25519 tarkibi (private key)
#   DO_SSH_PORT               = 22
#
# Deploy xabarnomasi uchun (ixtiyoriy):
#   TELEGRAM_DEPLOY_CHAT_ID   = admin chat ID
#   TELEGRAM_DEPLOY_BOT_TOKEN = alohida monitoring bot tokeni
